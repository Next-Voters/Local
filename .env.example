# Find all Open Code MCP env variables within .opencode/.env.example

# Server Configuration
PORT=8000
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000

# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key

# Email (SMTP)
SMTP_EMAIL=your_email@example.com
SMTP_APP_PASSWORD=your_app_password

# External APIs
TAVILY_API_KEY=your_tavily_api_key
# OpenAI (automatically picked up by langchain-openai)
OPENAI_API_KEY=your_openai_api_key

# HuggingFace (suppresses rate-limit warnings for LLMLingua-2 model downloads)
HF_TOKEN=your_huggingface_token

# Google Calendar (optional — enables calendar event creation for legislative dates)
# Paste the full JSON content of your GCP service account key (download from GCP Console → IAM → Service Accounts → Keys)
# Share your Google Calendar with the service account email and grant "Make changes to events"
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"..."}